# PlatformIO build artifacts
.pio/

# VSCode metadata that platformio regenerates per machine
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/

# ESP-IDF generated sdkconfig. We commit sdkconfig.defaults and any per-board
# sdkconfig.<board>.defaults overrides (e.g. sdkconfig.ee02.defaults); the
# generated per-env sdkconfig.<env> files stay ignored.
sdkconfig
sdkconfig.*
!sdkconfig.defaults
!sdkconfig.*.defaults

# ESP-IDF component manager
managed_components/
dependencies.lock

# Editor/IDE
.idea/
*.swp
.DS_Store

# Local secrets file (template lives at include/secrets.example.h).
# `secrets.h.*` covers backups left behind by tools/release.sh and the
# travel-setup move-aside pattern (secrets.h.bak, secrets.h.release-backup.*).
secrets.h
secrets.h.*
!secrets.example.h

# Release artifacts staged by tools/release.sh; final copies live in GitHub Releases
/release/
